flowchart LR
    subgraph Required_Materials[Required Material Pool]
        R1[Required Material 1]
        R2[Required Material 2]
        R3[Required Material 3]
        R4[Required Material 4+]
    end
    subgraph Arrangement_Slots[Arrangement Slots]
